# TradeFirewall — copy to `.env.local` (never commit real secrets)

# --- SoSoValue (required for live risk reports) ---
# Get a key from https://sosovalue.com/developer/dashboard
# Official OpenAPI: https://openapi.sosovalue.com/openapi/v1 (header: x-soso-api-key)
SOSOVALUE_API_KEY=
# Optional override (default is the public OpenAPI base URL)
# SOSOVALUE_API_BASE_URL=https://openapi.sosovalue.com/openapi/v1

# --- SoDEX public market data (no signing key required) ---
# Default: testnet public REST (recommended; no mainnet execution in app)
SODEX_USE_TESTNET=true
SODEX_TESTNET_SPOT_URL=https://testnet-gw.sodex.dev/api/v1/spot
SODEX_TESTNET_PERPS_URL=https://testnet-gw.sodex.dev/api/v1/perps

# Optional mainnet URLs (read-only market data only; app never submits mainnet trades)
# SODEX_USE_TESTNET=false
# SODEX_MAINNET_SPOT_URL=https://mainnet-gw.sodex.dev/api/v1/spot
# SODEX_MAINNET_PERPS_URL=https://mainnet-gw.sodex.dev/api/v1/perps

# Legacy: if you still have NEXT_PUBLIC_SOSOVALUE_API_KEY it is read as a fallback,
# but prefer SOSOVALUE_API_KEY so the key is server-only.
